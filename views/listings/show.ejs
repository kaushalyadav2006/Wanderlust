<% layout("/layouts/boilerplate")%>
<div class="row">
  <div class="col-6 offset-3 mt-3 mb-4">
    <h3><%= listing.title%></b></h3>
    <div class="card col-6 offset-3 show-card listing-card ">
  </div>

      <img src="<%= listing.image%>" class="card-img-top show-img" alt="listing_images">
      <div class="card-body">
        <p class="card-text">
          <%= listing.description%> <br>
          <br>
          &#8377; <%= listing.price?.toLocaleString("en-IN") || "N/A" %> <br>
          <%= listing.location%> <br>
          <%= listing.country%> <br>
        </p>
      </div>
    </div>


    <div class="btns">
       <a href="/listings/<%= listing._id %>/edit" 
        class="btn btn-dark col-1 offset-3 edit-btn">Edit
      </a>
   
      <form action="/listings/<%=listing._id%>?_method=Delete" method="post">
        <button class="btn btn-dark offset-5 ">Delete</button>
      </form>
      
    </div>

    <div class="col-8 offset-3 mb-3">
      <hr>
      <h4>Leave a review</h4>
      <form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate class="needs-validation" >
        <div class="row">
          <div class="mt-3 mb-3 col-5">
            <label for="name" class="form-label"><b>Name</b></label>
            <input
              type="text"
              id="name"
              name="review[name]"
              class="form-control"
              required
            >
            <div class="invalid-feedback ">
              Please add your name.
            </div>
          </div>

          <div class="mt-4 mb-3 col-7">
            <label for="rating" class="form-label ">  <b>Rating</b></label>
            <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
          </div>
        </div>
        <div class="mt-3 mb-3">
          <b>Comment </b>
          <label for="comment" class="form-label"></label>
          <textarea name="review[comment]" 
          id="comment" 
          class="form-control"
          rows="5"
          cols="30"
          required></textarea>

          <div class="invalid-feedback">
            Please add some comments for review!
          </div>

        </div>
        
        <button class="btn btn-outline-dark mt-2 ">Submit</button>
      </form>

      <hr>
      <p><b>All Reviews </b></p>
      <div class="row">
        <% if (reviews.length === 0) { %>
        <p class="text-muted">No reviews yet.</p>
        <% } else { %>
          <% for (let review of reviews) { %>
            <div class="card col-5 ms-3 mt-3 mb-3">
            <div class="card-body">
            <h5 class="card-title"><%= review.name || "Anonymous" %></h5>
            <p class="card-text"><%= review.comment%></p>
            <p class="card-text"><%= review.rating%> stars</p>
            </div>

            <form action="/listings/<%= listing._id%>/reviews/<%= review._id%>?_method=DELETE" method="post">
              <button class="btn btn-sm btn-dark mb-3 mt-3">Delete</button>
            </form>
            </div>
          <% } %>
        <% } %>
      </div>


    </div>
</div>

