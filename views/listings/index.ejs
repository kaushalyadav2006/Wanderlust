<% layout("/layouts/boilerplate") %>
<% const activeCategory = typeof category !== "undefined" ? category : null; %>

<% const filters = [
  { icon: "fa-fire", label: "Trending" },
  { icon: "fa-bed", label: "Rooms" },
  { icon: "fa-mountain-city", label: "Iconic Cities" },
  { icon: "fa-mountain", label: "Mountains" },
  { icon: "fa-fort-awesome", label: "Castles", brand: true },
  { icon: "fa-person-swimming", label: "Amazing Pools" },
  { icon: "fa-campground", label: "Camping" },
  { icon: "fa-tractor", label: "Farms" },
  { icon: "fa-snowflake", label: "Arctic", regular: true },
  { icon: "fa-igloo", label: "Domes" },
  { icon: "fa-sailboat", label: "Boats" }
]; %>

<div class="row align-items-center">

  <!-- FILTERS -->
  <div class="col-lg-8 col-md-8 col-sm-12">
    <div class="filters-scroll-wrap">

      <!-- LEFT BUTTON -->
      <button
        type="button"
        class="scroll-btn"
        id="scrollLeft"
        aria-label="Scroll filters left"
      >
        <i class="fa-solid fa-chevron-left"></i>
      </button>

      <!-- FILTER LIST (IMPORTANT WRAPPER) -->
      <div id="filters" class="horizontal-filters">

        <% filters.forEach(f => { %>
          <div
            class="filter <%= activeCategory === f.label ? 'active' : '' %>"
            title="Show <%= f.label %> listings"
            tabindex="0"
            role="button"
          >
            <div>
              <i class="fa<%= f.brand ? '-brands' : f.regular ? '-regular' : '-solid' %> <%= f.icon %>"></i>
            </div>
            <p><%= f.label %></p>
          </div>
        <% }) %>

        <!-- SHOW ALL BUTTON -->
        <% if (activeCategory) { %>
          <a
            href="/listings"
            class="btn btn-outline-secondary btn-sm ms-2 align-self-center"
            id="clearFilter"
          >
            List All
          </a>
        <% } %>

      </div>

      <!-- RIGHT BUTTON -->
      <button
        type="button"
        class="scroll-btn"
        id="scrollRight"
        aria-label="Scroll filters right"
      >
        <i class="fa-solid fa-chevron-right"></i>
      </button>

    </div>
  </div>

  <!-- TAX TOGGLE -->
  <div class="col-lg-4 col-md-4 d-none d-md-flex justify-content-end">
    <div class="tax-toggle">
      <div class="form-check form-switch">
        <input
          class="form-check-input"
          type="checkbox"
          role="switch"
          id="flexSwitchCheckDefault"
        >
        <label
          class="form-check-label"
          for="flexSwitchCheckDefault"
        >
          Display total after taxes
        </label>
      </div>
    </div>
  </div>

</div>

<!-- LISTINGS -->
  <div class="row row-cols-2 row-cols-md-2 row-cols-lg-3 g-3 mt-3">
  <% for (let listing of allListings) { %>
    <a href="/listings/<%= listing._id %>" class="listing-link">
      <div class="card col listing-card">

        <img
          src="<%= listing.image.url %>"
          class="card-img-top"
          alt="<%= listing.title %>"
          style="height: 16rem;"
        />

        <div class="card-img-overlay"></div>

<div class="card-body py-2">
  <div class="d-flex justify-content-between align-items-center mb-1">
    <h6 class="fw-bold mb-0">
      <%= listing.title %>
    </h6>

    <span class="badge rounded-pill text-bg-light px-2 py-1">
      <%= listing.category %>
    </span>
  </div>

  <p class="text-muted mb-1 small">
    <i class="fa-solid fa-location-dot me-1"></i>
    <%= listing.location %>, <%= listing.country %>
  </p>

  <p class="mb-0">
    <span class="fw-bold">
      &#8377; <%= listing.price?.toLocaleString("en-IN") %>
    </span>
    <span class="text-muted small"> / night</span>
    <span class="tax-info text-success small ms-1">
     +18% GST
    </span
  </p>
</div>

      </div>
    </a>
  <% } %>
</div>

<script src="/js/filterScroll.js"></script>
